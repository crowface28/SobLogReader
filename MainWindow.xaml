<Window x:Class="SobLogReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Combat Log Parser" Height="700" Width="1000" Background="#1E1E1E" Foreground="#D4D4D4"
        Icon="Assets/app_icon.ico">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="COMBAT LOG PARSER" FontSize="11" Foreground="#569CD6" FontWeight="SemiBold"/>
                <TextBlock x:Name="FileStatusText" Text="No file loaded" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="1" Content="Open Combat Log" Width="150" Height="32" 
                    Background="#3F3F46" Foreground="White" BorderBrush="#555" BorderThickness="1"
                    Cursor="Hand" VerticalAlignment="Center" Click="OpenFile_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#252526" BorderBrush="#333" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Encounters" FontWeight="Bold" Margin="10" Foreground="#569CD6"/>
                    <ListBox x:Name="FightsListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="#D4D4D4" SelectionChanged="FightsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding MobName}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding DurationStr}" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Background="#252526" BorderBrush="#333" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <!-- Welcome / Empty State Panel -->
                    <Grid x:Name="WelcomePanel" Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Circular Emblem Graphic -->
                            <Image Source="Assets/emblem.png" Height="200" Width="200" Margin="0,0,0,20" Opacity="0.5"/>
                            <TextBlock Text="SHARDS OF BRITANNIA" FontSize="18" FontWeight="Bold" Foreground="#CE9178" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Select an encounter or load a combat log to view stats" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Stats Panel (starts Hidden) -->
                    <Grid x:Name="StatsPanel" Visibility="Hidden" Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="StatMobName" FontSize="24" FontWeight="Bold" Foreground="#4EC9B0" Margin="0,0,0,15"/>

                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">
                            <StackPanel Margin="5">
                                <TextBlock Text="Player Damage" FontWeight="Bold" Foreground="#C586C0"/>
                                <TextBlock x:Name="StatPlayerDmg" Text="Max: 0 | Min: 0 | Avg: 0"/>
                                <TextBlock x:Name="StatPlayerDps" Text="DPS: 0.0" FontWeight="SemiBold"/>
                                <TextBlock x:Name="StatPlayerAcc" Text="Hit Rate: 0% (0 Hits / 0 Misses)"/>
                            </StackPanel>

                            <StackPanel Margin="5">
                                <TextBlock Text="Incoming Damage (Mob -> You)" FontWeight="Bold" Foreground="#F44336"/>
                                <TextBlock x:Name="StatMobDmg" Text="Max: 0 | Min: 0 | Avg: 0"/>
                                <TextBlock x:Name="StatMobDps" Text="DPS: 0.0" FontWeight="SemiBold"/>
                                <TextBlock x:Name="StatMobAcc" Text="Hit Rate: 0% (0 Hits / 0 Misses)"/>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Grid.Row="2" Margin="5,0,0,15">
                            <TextBlock Text="Pet Damage" FontWeight="Bold" Foreground="#CE9178"/>
                            <TextBlock x:Name="StatPetDmg" Text="Max: 0 | Min: 0 | Avg: 0"/>
                            <TextBlock x:Name="StatPetDps" Text="DPS: 0.0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StatPetAcc" Text="Hit Rate: 0% (0 Hits / 0 Misses)"/>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Text="Loot Collected" FontWeight="Bold" Foreground="#DCDCAA" Margin="5,0,0,5"/>

                        <ListBox Grid.Row="4" x:Name="StatLoot" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333" Foreground="#D4D4D4" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

        <Border Grid.Row="3" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Raw Event Log" FontWeight="Bold" Margin="10,5" Foreground="#569CD6"/>
                <TextBox x:Name="RawLogBox" Grid.Row="1" IsReadOnly="True" Background="#1E1E1E" Foreground="#AAAAAA" BorderThickness="0" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="5"/>
            </Grid>
        </Border>
    </Grid>
</Window>